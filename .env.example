# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=development                 # development | staging | production
APP_NAME="Finance Ops AI Manager"
APP_VERSION=0.1.0
SECRET_KEY=your-super-secret-key-change-in-production
API_KEY_HEADER=X-API-Key           # header name for API key auth
API_KEYS=key1,key2                 # comma-separated valid API keys

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8192

# ─── Database (PostgreSQL async) ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finance_ops
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=3600

# ─── QuickBooks Online ────────────────────────────────────────────────────────
QBO_CLIENT_ID=your-qbo-client-id
QBO_CLIENT_SECRET=your-qbo-client-secret
QBO_REDIRECT_URI=http://localhost:8000/api/v1/integrations/qbo/callback
QBO_ENVIRONMENT=sandbox             # sandbox | production
QBO_BASE_URL_SANDBOX=https://sandbox-quickbooks.api.intuit.com
QBO_BASE_URL_PROD=https://quickbooks.api.intuit.com
QBO_MINOR_VERSION=70

# ─── Asana ────────────────────────────────────────────────────────────────────
ASANA_ACCESS_TOKEN=your-asana-personal-access-token
ASANA_WORKSPACE_GID=your-workspace-gid
ASANA_DEFAULT_PROJECT_GID=your-default-project-gid

# ─── Ramp ─────────────────────────────────────────────────────────────────────
RAMP_CLIENT_ID=your-ramp-client-id
RAMP_CLIENT_SECRET=your-ramp-client-secret
RAMP_BASE_URL=https://api.ramp.com/developer/v1

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=csv,xlsx,xls,pdf,txt,json

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                     # json | console
